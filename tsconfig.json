{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "emitDeclarationOnly": false,
    "noEmit": true,
    "paths": {
      "@fml/*": [
        "packages/*/src"
      ]
    }
  },
  "references": [
    { "path": "packages/controls" },
    { "path": "packages/core" },
    { "path": "packages/layouts" },
    { "path": "packages/react" },
    { "path": "packages/util-types" }
  ],
  "exclude": [
    "packages/*/src/**/*.test.*",
    "packages/*/src/**/*.stories.*"
  ]
}
